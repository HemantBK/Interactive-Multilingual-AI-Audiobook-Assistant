# Cloudflare Pages — HTTP response headers
# Applied to all routes under the Pages project.
# Build step copies this file to dist/_headers (see frontend/vite.config.ts).
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-Permitted-Cross-Domain-Policies: none
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(), camera=(), geolocation=(), payment=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  # CSP — Day 26 review.
  #   script-src 'unsafe-eval' is required ONLY by Tailwind Play CDN's
  #   in-browser JIT. Drop it when we move to compiled Tailwind (Day 38 polish).
  #   connect-src lists every origin the SPA legitimately fetches from:
  #     - Supabase REST + Storage + auth + realtime (https + wss)
  #     - HF Space backend (https://*.hf.space) — also serves /tts signed URLs
  #     - Sentry ingest (errors + traces)
  #     - PostHog ingest (events) — declined-consent users still resolve DNS
  #     - Supabase signed-URL CDN (per-bucket subdomains route through *.supabase.co)
  #   worker-src 'self' blob: covers the pdfjs worker (vite emits a hashed
  #     same-origin URL; pdf.js blobs the worker payload internally).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.hf.space https://*.ingest.sentry.io https://*.sentry.io https://us.i.posthog.com https://eu.i.posthog.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
