{
  "name": "aria-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src e2e",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,css,html}\" \"e2e/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,js,css,html}\" \"e2e/**/*.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@sentry/react": "^8.40.0",
    "@supabase/supabase-js": "^2.47.10",
    "dompurify": "^3.2.1",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "pdfjs-dist": "^4.8.69",
    "posthog-js": "^1.181.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-i18next": "^15.4.0",
    "react-markdown": "^9.0.1",
    "react-pdf": "^9.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.48.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.2.0"
  }
}
