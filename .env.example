# ============================================================================
# ARIA — Environment Variables (example)
# ============================================================================
# Copy this file to `.env` and fill in actual values.
# NEVER commit `.env` to git. Secrets belong in Hugging Face Space secrets
# (backend) and Cloudflare Pages environment variables (frontend).
# ============================================================================

# ---------- Environment ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Backend (FastAPI on Hugging Face Spaces) ----------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (backend uses service_role key for server-side operations)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # server-only, NEVER expose to browser

# AI providers (all server-side only)
GEMINI_API_KEY=
GROQ_API_KEY=

# Rate limits
RATE_LIMIT_PER_IP_PER_MIN=10
RATE_LIMIT_DAILY_UPLOADS=10
RATE_LIMIT_DAILY_QUERIES=500
RATE_LIMIT_DAILY_TTS_CHARS=100000

# Upload limits
MAX_UPLOAD_MB=50

# Global kill switch (set to "true" to reject all AI requests — emergency use)
KILL_SWITCH=false

# Observability
SENTRY_DSN_BACKEND=
POSTHOG_API_KEY_BACKEND=

# ---------- Frontend (Cloudflare Pages) ----------
# NOTE: Anything prefixed VITE_ is bundled into the browser and is PUBLIC.
# Never put secrets here.
VITE_API_BASE_URL=http://localhost:7860
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SENTRY_DSN_FRONTEND=
VITE_POSTHOG_API_KEY=
